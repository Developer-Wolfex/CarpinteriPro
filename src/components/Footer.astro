---
// src/components/Footer.astro
---

<footer style="background:var(--color-bark-800);border-top:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-10">

      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl" aria-hidden="true">🪵</span>
          <span class="font-display text-xl font-bold" style="color:var(--color-wood-100);">
            Carpintería<span style="color:var(--color-wood-500);">Pro</span>
          </span>
        </div>
        <p class="text-sm leading-relaxed max-w-xs" style="color:var(--color-wood-400);">
          Academia y manuales prácticos de carpintería: materiales, proyectos reales y rutas de aprendizaje de básico a avanzado.
        </p>
      </div>

      <!-- Aprende -->
      <div>
        <h3 class="font-display font-bold mb-4" style="color:var(--color-wood-200);">Aprende</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['Introducción', '/aprende'],
            ['Nivel Básico', '/aprende/basico'],
            ['Nivel Intermedio', '/aprende/intermedio'],
            ['Nivel Avanzado', '/aprende/avanzado'],
            ['Materiales', '/materiales'],
            ['Melamina', '/melamina'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="transition-colors" style="color:var(--color-wood-400);" onmouseover="this.style.color='var(--color-wood-600)'" onmouseout="this.style.color='var(--color-wood-400)'">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contenido -->
      <div>
        <h3 class="font-display font-bold mb-4" style="color:var(--color-wood-200);">Contenido</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['Proyectos', '/proyectos'],
            ['Manuales', '/manuales'],
            ['Blog', '/blog'],
            ['Glosario', '/glosario'],
            ['Recursos', '/recursos'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="transition-colors" style="color:var(--color-wood-400);" onmouseover="this.style.color='var(--color-wood-600)'" onmouseout="this.style.color='var(--color-wood-400)'">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="font-display font-bold mb-4" style="color:var(--color-wood-200);">Información</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['Sobre Nosotros', '/sobre-nosotros'],
            ['Contacto',       '/contacto'],
            ['Política de Privacidad', '/privacidad'],
            ['DMCA', '/dmca'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="transition-colors" style="color:var(--color-wood-400);" onmouseover="this.style.color='var(--color-wood-600)'" onmouseout="this.style.color='var(--color-wood-400)'">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4" style="border-top:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
      <p class="text-xs" style="color:var(--color-wood-400);">
        © {new Date().getFullYear()} CarpinteríaPro. Todos los derechos reservados.
      </p>
      <p class="text-xs" style="color:var(--color-wood-400);">
        Hecho con 🪵 para la comunidad carpintera
      </p>
    </div>
  </div>
</footer>
