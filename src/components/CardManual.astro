---
// src/components/CardManual.astro
import { CATEGORIAS } from '../data/manuales';
import type { Manual } from '../data/manuales';

interface Props {
  manual: Manual;
}

const { manual } = Astro.props;
const cat = CATEGORIAS[manual.categoria];

const nivelColor: Record<string, string> = {
  'Básico':     'color: var(--color-olive-600);',
  'Intermedio': 'color: var(--color-wood-600);',
  'Avanzado':   'color: var(--color-wood-700);',
};
---

<a href={`/manuales/${manual.slug}`} class="card-manual group block" data-cat={manual.categoria}>

  <!-- Imagen -->
  <div class="relative h-44 overflow-hidden" style="background:var(--color-bark-800);">

    {manual.imagen ? (
      <img
        src={manual.imagen}
        alt={`${manual.titulo} - Manual de carpintería`}
        width="400"
        height="176"
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
    ) : null}

    <!-- Fallback con emoji de categoría -->
    <div class="absolute inset-0 flex items-center justify-center" style={`background:var(--color-bark-800); display:${manual.imagen ? 'none' : 'flex'};`}>
      <span class="text-6xl opacity-25" aria-hidden="true">{cat.emoji}</span>
    </div>

    <!-- Overlay gradiente para que los badges se lean bien -->
    <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(to top, color-mix(in srgb, var(--color-wood-100) 35%, transparent), transparent 60%);" />

    <!-- Badge categoría -->
    <div class="absolute top-3 left-3">
      <span class="badge-category">
        {cat.emoji} {cat.label}
      </span>
    </div>

    <!-- Badge destacado -->
    {manual.destacado && (
      <div class="absolute top-3 right-3">
        <span class="badge-category" style="background:var(--color-wood-500); color:#fff8f0; border-color:var(--color-wood-500);">⭐ Destacado</span>
      </div>
    )}
  </div>

  <!-- Contenido -->
  <div class="p-5">
    <h3 class="font-display font-bold text-lg leading-snug mb-2 transition-colors" style="color:var(--color-wood-100);">
      {manual.titulo}
    </h3>
    <p class="text-sm leading-relaxed line-clamp-2 mb-4" style="color:var(--color-wood-400);">
      {manual.descripcion}
    </p>

    <div class="flex items-center justify-between text-xs">
      <div class="flex items-center gap-3">
        <span class="font-bold" style={nivelColor[manual.nivel]}>
          {manual.nivel}
        </span>
        <span style="color:var(--color-wood-800);">·</span>
        <span style="color:var(--color-wood-400);">⏱ {manual.duracion}</span>
      </div>
      <span style="color:var(--color-wood-400);">
        {new Date(manual.fecha).toLocaleDateString('es-PE', { month: 'short', year: 'numeric' })}
      </span>
    </div>
  </div>

</a>
