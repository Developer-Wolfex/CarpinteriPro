---
// src/components/Sidebar.astro
import { CATEGORIAS, MANUALES } from '../data/manuales';
import type { Categoria } from '../data/manuales';
import AdSense from './AdSense.astro';

const conteo = Object.fromEntries(
  Object.keys(CATEGORIAS).map(cat => [
    cat,
    MANUALES.filter(m => m.categoria === cat).length
  ])
);
---

<aside class="space-y-6">

  <!-- Filtro por categoría -->
  <div class="rounded-2xl p-5" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent); box-shadow:var(--shadow-soft);">
    <h2 class="font-display font-bold text-lg mb-4 flex items-center gap-2" style="color:var(--color-wood-200);">
      <span aria-hidden="true">📂</span> Manuales por Tipo
    </h2>

    <nav class="space-y-1" aria-label="Filtrar manuales por categoría">
      <a
        href="/manuales"
        data-cat=""
        class="sidebar-link sidebar-filter"
      >
        <span aria-hidden="true">🗂️</span>
        <span class="flex-1">Todos los manuales</span>
        <span class="text-xs px-2 py-0.5 rounded-full" style="background:var(--color-bark-800); color:var(--color-wood-400);">
          {MANUALES.length}
        </span>
      </a>

      {(Object.entries(CATEGORIAS) as [Categoria, typeof CATEGORIAS[Categoria]][]).map(([key, cat]) => (
        <a
          href={`/manuales?cat=${key}`}
          data-cat={key}
          class="sidebar-link sidebar-filter"
        >
          <span aria-hidden="true">{cat.emoji}</span>
          <span class="flex-1">{cat.label}</span>
          <span class="text-xs px-2 py-0.5 rounded-full" style="background:var(--color-bark-800); color:var(--color-wood-400);">
            {conteo[key]}
          </span>
        </a>
      ))}
    </nav>
  </div>

  <!-- Niveles -->
  <div class="rounded-2xl p-5" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent); box-shadow:var(--shadow-soft);">
    <h2 class="font-display font-bold text-lg mb-4 flex items-center gap-2" style="color:var(--color-wood-200);">
      <span aria-hidden="true">📊</span> Por Nivel
    </h2>
    <div class="space-y-2">
      {[
        { nivel: 'Básico',     color: 'var(--color-olive-500)', porcentaje: 40 },
        { nivel: 'Intermedio', color: 'var(--color-wood-500)',  porcentaje: 45 },
        { nivel: 'Avanzado',   color: 'var(--color-wood-700)',  porcentaje: 15 },
      ].map(item => (
        <div class="flex items-center gap-3">
          <span class="text-xs w-20" style="color:var(--color-wood-400);">{item.nivel}</span>
          <div class="flex-1 rounded-full h-1.5" style="background:var(--color-bark-800);">
            <div class="h-1.5 rounded-full" style={`width:${item.porcentaje}%; background:${item.color};`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- AdSense sidebar -->
  <AdSense slot="0000000001" format="rectangle" />

  <!-- Manuales recientes -->
  <div class="rounded-2xl p-5" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent); box-shadow:var(--shadow-soft);">
    <h2 class="font-display font-bold text-lg mb-4 flex items-center gap-2" style="color:var(--color-wood-200);">
      <span aria-hidden="true">🔥</span> Más recientes
    </h2>
    <div class="space-y-3">
      {MANUALES.slice(0, 4).map(m => (
        <a href={`/manuales/${m.slug}`} class="flex gap-3 group">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center text-xl flex-shrink-0" style="background:var(--color-bark-800);">
            {CATEGORIAS[m.categoria].emoji}
          </div>
          <div>
            <p class="text-xs font-bold leading-snug line-clamp-2 transition-colors" style="color:var(--color-wood-200);">
              {m.titulo}
            </p>
            <p class="text-xs mt-0.5" style="color:var(--color-wood-400);">{m.nivel}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

</aside>

<!-- ✅ JS que activa el link correcto según ?cat= en la URL -->
<script>
  function activarSidebarLink() {
    const cat = new URLSearchParams(window.location.search).get('cat') || '';

    document.querySelectorAll('.sidebar-filter').forEach(link => {
      const linkCat = link.getAttribute('data-cat') || '';

      if (linkCat === cat) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  }

  activarSidebarLink();

  window.addEventListener('popstate', activarSidebarLink);

  const originalPushState = history.pushState.bind(history);
  history.pushState = function(...args) {
    originalPushState(...args);
    activarSidebarLink();
  };
</script>
