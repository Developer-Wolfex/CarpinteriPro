---
// src/components/AdSense.astro
// =====================================================
// Componente para anuncios de Google AdSense
// Reemplaza data-ad-client y data-ad-slot con tus IDs reales
// =====================================================
interface Props {
  slot: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
  className?: string;
}

const { slot, format = 'auto', className = '' } = Astro.props;

// Tu Publisher ID de AdSense (reemplazar)
const ADSENSE_CLIENT = 'ca-pub-XXXXXXXXXXXXXXXXX';
---

<div class={`adsense-container my-6 text-center ${className}`}>
  <!-- AVISO: Reemplaza XXXXXXXXXXXXXXXXX con tu Publisher ID de AdSense -->
  <!-- Una vez aprobado por Google, descomenta el script en BaseLayout.astro -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={ADSENSE_CLIENT}
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
  <script>((window as any).adsbygoogle = (window as any).adsbygoogle || []).push({});</script>
</div>
