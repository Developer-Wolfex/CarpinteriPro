---
// src/pages/manuales/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardManual from '../../components/CardManual.astro';
import Sidebar from '../../components/Sidebar.astro';
import AdSense from '../../components/AdSense.astro';
import { MANUALES, CATEGORIAS } from '../../data/manuales';
import type { Categoria } from '../../data/manuales';

const categorias = Object.entries(CATEGORIAS) as [Categoria, typeof CATEGORIAS[Categoria]][];
---

<BaseLayout
  title="Todos los Manuales de Carpintería – CarpinteríaPro"
  description="Todos los manuales de carpintería: melamina, madera, MDF, bambú y herramientas."
>

  <!-- Breadcrumb -->
  <div style="border-bottom:1px solid color-mix(in srgb, var(--color-wood-800) 50%, transparent); background:var(--color-bark-900);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs" style="color:var(--color-wood-400);" aria-label="Ruta de navegación">
        <a href="/" class="transition-colors" style="color:var(--color-wood-400);">Inicio</a>
        <span>/</span>
        <span style="color:var(--color-wood-200);">Manuales</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- ─── CONTENIDO PRINCIPAL ─── -->
      <div class="flex-1 min-w-0">

        <div class="mb-8">
          <h1 id="page-title" class="font-display text-4xl font-bold mb-3 flex items-center gap-3" style="color:var(--color-wood-100);">
            <span aria-hidden="true">📚</span> Todos los Manuales
          </h1>
          <p id="page-count" style="color:var(--color-wood-400);">
            {MANUALES.length} manuales disponibles
          </p>
        </div>

        <!-- Filtros rápidos (tabs) -->
        <div class="flex flex-wrap gap-2 mb-8" role="group" aria-label="Filtrar por categoría">
          <a
            href="/manuales"
            data-cat=""
            class="filter-btn px-4 py-2 rounded-lg text-sm font-bold transition-all duration-200 border"
            style="background:var(--color-wood-500); color:#fff8f0; border-color:var(--color-wood-500);"
          >
            Todos
          </a>
          {categorias.map(([key, cat]) => (
            <a
              href={`/manuales?cat=${key}`}
              data-cat={key}
              class="filter-btn px-4 py-2 rounded-lg text-sm font-bold transition-all duration-200 border flex items-center gap-2"
              style="background:var(--color-bark-900); color:var(--color-wood-400); border-color:color-mix(in srgb, var(--color-wood-800) 70%, transparent);"
            >
              <span aria-hidden="true">{cat.emoji}</span> {cat.label}
            </a>
          ))}
        </div>

        <!-- Grid de manuales — renderizado por Astro (SEO/CLS-friendly), el JS solo oculta/muestra -->
        <div id="manuales-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
          {MANUALES.map(manual => (
            <div class="manual-item" data-cat={manual.categoria}>
              <CardManual manual={manual} />
            </div>
          ))}
        </div>

        <!-- Estado vacío -->
        <div id="empty-state" class="hidden text-center py-20" style="color:var(--color-wood-400);">
          <p class="text-5xl mb-4" aria-hidden="true">🔍</p>
          <p class="text-xl">No hay manuales en esta categoría aún.</p>
          <a href="/manuales" class="mt-4 inline-block underline" style="color:var(--color-wood-500);">Ver todos</a>
        </div>

        <AdSense slot="0000000005" format="horizontal" className="mt-10" />

      </div>

      <!-- ─── SIDEBAR ─── -->
      <div class="w-full lg:w-72 flex-shrink-0">
        <div class="sticky top-20">
          <Sidebar />
        </div>
      </div>

    </div>
  </div>

</BaseLayout>

<script define:vars={{ CATEGORIAS }}>
  function getCatFromURL() {
    return new URLSearchParams(window.location.search).get('cat') || '';
  }

  function actualizarVista(cat) {
    const items   = document.querySelectorAll('#manuales-grid .manual-item');
    const titulo  = document.getElementById('page-title');
    const contador = document.getElementById('page-count');
    const grid    = document.getElementById('manuales-grid');
    const empty   = document.getElementById('empty-state');
    const btns    = document.querySelectorAll('.filter-btn');

    let visibles = 0;
    items.forEach(item => {
      const match = !cat || item.getAttribute('data-cat') === cat;
      item.style.display = match ? '' : 'none';
      if (match) visibles++;
    });

    btns.forEach(btn => {
      const btnCat = btn.getAttribute('data-cat') || '';
      const active = btnCat === cat;
      btn.style.background = active ? 'var(--color-wood-500)' : 'var(--color-bark-900)';
      btn.style.color = active ? '#fff8f0' : 'var(--color-wood-400)';
      btn.style.borderColor = active ? 'var(--color-wood-500)' : 'color-mix(in srgb, var(--color-wood-800) 70%, transparent)';
    });

    if (cat && CATEGORIAS[cat]) {
      titulo.innerHTML = `<span aria-hidden="true">${CATEGORIAS[cat].emoji}</span> Manuales de ${CATEGORIAS[cat].label}`;
    } else {
      titulo.innerHTML = `<span aria-hidden="true">📚</span> Todos los Manuales`;
    }

    contador.textContent = `${visibles} manual${visibles !== 1 ? 'es' : ''} disponible${visibles !== 1 ? 's' : ''}`;
    grid.classList.toggle('hidden', visibles === 0);
    empty.classList.toggle('hidden', visibles !== 0);
  }

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const cat = btn.getAttribute('data-cat');
      const newURL = cat ? `?cat=${cat}` : '/manuales';
      history.pushState({}, '', newURL);
      actualizarVista(cat);
    });
  });

  actualizarVista(getCatFromURL());

  window.addEventListener('popstate', () => {
    actualizarVista(getCatFromURL());
  });
</script>
