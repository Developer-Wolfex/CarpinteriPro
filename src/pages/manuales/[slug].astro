---
// src/pages/manuales/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import CardManual from '../../components/CardManual.astro';
import AdSense from '../../components/AdSense.astro';
import { MANUALES, CATEGORIAS, getManualesByCategoria } from '../../data/manuales';
import type { Manual } from '../../data/manuales';
import { marked } from 'marked';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

export async function getStaticPaths() {
  return MANUALES.map(manual => ({
    params: { slug: manual.slug },
    props: { manual },
  }));
}

interface Props { manual: Manual; }
const { manual } = Astro.props;

const cat = CATEGORIAS[manual.categoria];
const relacionados = getManualesByCategoria(manual.categoria)
  .filter(m => m.slug !== manual.slug)
  .slice(0, 3);

const nivelStyle: Record<string, string> = {
  'Básico':     'color:var(--color-olive-600); background:color-mix(in srgb, var(--color-olive-500) 12%, transparent);',
  'Intermedio': 'color:var(--color-wood-600); background:color-mix(in srgb, var(--color-wood-500) 12%, transparent);',
  'Avanzado':   'color:var(--color-wood-700); background:color-mix(in srgb, var(--color-wood-700) 12%, transparent);',
};

let contenidoHTML = '';
try {
  const mdPath = join(process.cwd(), 'src/content/manuales', `${manual.slug}.md`);
  const mdRaw = await readFile(mdPath, 'utf-8');
  const sinFrontmatter = mdRaw.replace(/^---[\s\S]*?---\n/, '');
  contenidoHTML = await marked(sinFrontmatter);
} catch {
  contenidoHTML = '';
}

const fechaISO = manual.fecha;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: manual.titulo,
  description: manual.descripcion,
  datePublished: fechaISO,
  dateModified: fechaISO,
  author: { '@type': 'Organization', name: 'CarpinteríaPro' },
  publisher: { '@type': 'Organization', name: 'CarpinteríaPro' },
  ...(manual.imagen ? { image: new URL(manual.imagen, Astro.site).toString() } : {}),
};
---

<BaseLayout
  title={`${manual.titulo} | Carpintería Pro`}
  description={manual.descripcion}
  keywords={manual.keywords?.join(', ')}
  type="article"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Breadcrumb -->
  <div style="border-bottom:1px solid color-mix(in srgb, var(--color-wood-800) 50%, transparent); background:var(--color-bark-900);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs flex-wrap" style="color:var(--color-wood-400);" aria-label="Ruta de navegación">
        <a href="/" class="transition-colors" style="color:var(--color-wood-400);">Inicio</a>
        <span>/</span>
        <a href="/manuales" class="transition-colors" style="color:var(--color-wood-400);">Manuales</a>
        <span>/</span>
        <a href={`/manuales?cat=${manual.categoria}`} class="transition-colors" style="color:var(--color-wood-400);">{cat.label}</a>
        <span>/</span>
        <span class="truncate max-w-[200px]" style="color:var(--color-wood-300);">{manual.titulo}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- ─── ARTÍCULO ─── -->
      <article class="flex-1 min-w-0">

        <div class="mb-8">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="badge-category">{cat.emoji} {cat.label}</span>
            <span class="badge-category" style={nivelStyle[manual.nivel]}>{manual.nivel}</span>
            <span class="text-xs" style="color:var(--color-wood-400);">⏱ {manual.duracion}</span>
            <span class="text-xs" style="color:var(--color-wood-400);">
              {new Date(manual.fecha).toLocaleDateString('es-PE', { day: 'numeric', month: 'long', year: 'numeric' })}
            </span>
          </div>

          <h1 class="font-display text-3xl md:text-5xl font-black leading-tight mb-4" style="color:var(--color-wood-100);">
            {manual.titulo}
          </h1>

          <p class="text-lg leading-relaxed" style="color:var(--color-wood-300);">
            {manual.descripcion}
          </p>
        </div>

        <!-- Imagen hero -->
        <div class="rounded-2xl overflow-hidden h-64 md:h-80 flex items-center justify-center mb-8" style="background:var(--color-bark-800); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
          {manual.imagen ? (
            <img src={manual.imagen} alt={manual.titulo} width="960" height="320" loading="eager" class="w-full h-full object-cover" />
          ) : (
            <span class="text-7xl opacity-30" aria-hidden="true">{cat.emoji}</span>
          )}
        </div>

        <AdSense slot="0000000006" format="in-article" className="mb-8" />

        <!-- ─── CONTENIDO DEL MANUAL ─── -->
        {contenidoHTML ? (
          <div
            class="prose max-w-none
              prose-headings:font-display
              prose-h2:text-2xl prose-h2:font-bold prose-h2:pb-2 prose-h2:mt-10
              prose-h3:text-lg prose-h3:font-semibold prose-h3:mt-6
              prose-p:leading-relaxed
              prose-table:w-full prose-table:text-sm"
            style="color:var(--color-wood-300); --tw-prose-headings:var(--color-wood-100); --tw-prose-body:var(--color-wood-300); --tw-prose-bold:var(--color-wood-200); --tw-prose-th-borders:var(--color-wood-800); --tw-prose-td-borders:var(--color-wood-800);"
            set:html={contenidoHTML}
          />
        ) : (
          <div class="rounded-xl p-6 text-center" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
            <p class="text-sm" style="color:var(--color-wood-400);">Contenido próximamente.</p>
          </div>
        )}

        <AdSense slot="0000000007" format="rectangle" className="mt-10" />

        <!-- ─── MANUALES RELACIONADOS ─── -->
        {relacionados.length > 0 && (
          <div class="mt-12">
            <h2 class="font-display text-2xl font-bold mb-6 flex items-center gap-2" style="color:var(--color-wood-100);">
              <span aria-hidden="true">🔗</span> También te puede interesar
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {relacionados.map(m => <CardManual manual={m} />)}
            </div>
          </div>
        )}

      </article>

      <!-- ─── SIDEBAR ─── -->
      <div class="w-full lg:w-72 flex-shrink-0">
        <div class="sticky top-20">
          <Sidebar />
        </div>
      </div>

    </div>
  </div>

</BaseLayout>
