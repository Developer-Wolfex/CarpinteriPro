---
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: Cambia estos datos
const email        = 'ventashot68@gmail.com';
const whatsapp     = '+51 932703431';
const whatsappLink = 'https://wa.me/51932703431';
const ubicacion    = 'Perú';
const horario      = 'Lun – Vie · 9am – 6pm';
const facebook     = 'https://facebook.com/carpinteriapro';
const tiktok       = 'https://tiktok.com/@carpinteriapro';
---

<BaseLayout
  title="Contacto – CarpinteríaPro"
  description="¿Tienes dudas sobre carpintería? Escríbenos. Respondemos en menos de 24 horas."
  keywords="contacto carpinteria, consulta carpinteria, carpinteria peru, mejor campinteria, melamina , madera"
>

<div class="min-h-screen relative overflow-hidden" style="background:#020c1b;">

  <!-- ── FONDO ANIMADO ── -->
  <div class="absolute inset-0 pointer-events-none" style="
    background-image:
      linear-gradient(rgba(100,255,218,0.025) 1px,transparent 1px),
      linear-gradient(90deg,rgba(100,255,218,0.025) 1px,transparent 1px);
    background-size:80px 80px;
  "></div>
  <div class="absolute pointer-events-none" style="width:700px;height:700px;left:-100px;top:-200px;background:radial-gradient(circle,rgba(8,145,178,0.12) 0%,transparent 65%);border-radius:50%;"></div>
  <div class="absolute pointer-events-none" style="width:500px;height:500px;right:-80px;bottom:0;background:radial-gradient(circle,rgba(100,255,218,0.07) 0%,transparent 65%);border-radius:50%;"></div>

  <!-- Breadcrumb -->
  <div class="relative border-b" style="border-color:rgba(21,94,117,0.25);background:rgba(2,12,27,0.6);backdrop-filter:blur(12px);">
    <div class="max-w-7xl mx-auto px-6 py-3 flex items-center gap-2 text-xs font-mono" style="color:rgba(100,255,218,0.35)">
      <a href="/" style="color:rgba(100,255,218,0.35);text-decoration:none;" onmouseover="this.style.color='#64ffda'" onmouseout="this.style.color='rgba(100,255,218,0.35)'">~/inicio</a>
      <span style="color:rgba(100,255,218,0.2)">/</span>
      <span style="color:#64ffda">contacto</span>
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">

    <!-- ── HEADER ── -->
    <div class="max-w-2xl mx-auto mb-16 text-center">
    <div class="flex items-center justify-center gap-3 mb-6">
        <div style="width:32px;height:1px;background:linear-gradient(90deg,transparent,#64ffda)"></div>
        <span class="font-mono text-xs tracking-[4px] uppercase" style="color:#64ffda;">Contacto</span>
        <div style="width:32px;height:1px;background:linear-gradient(90deg,#64ffda,transparent)"></div>
    </div>
    <h1 class="font-display font-black mb-5" style="font-size:clamp(40px,5.5vw,72px);color:#ecfeff;line-height:1;letter-spacing:-2px;">
        Hablemos de<br/>
        <span style="background:linear-gradient(135deg,#64ffda 0%,#06b6d4 50%,#0891b2 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
        tu proyecto
        </span>
    </h1>
    <p class="mx-auto" style="font-size:17px;line-height:1.75;color:rgba(165,243,252,0.6);max-width:480px;">
        ¿Tienes dudas sobre melamina, madera o quieres sugerir un manual?
        Escríbenos — respondemos todas las consultas.
    </p>
    </div>

    <!-- ── GRID PRINCIPAL ── -->
    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">

      <!-- COLUMNA IZQUIERDA — Info -->
      <div class="xl:col-span-4 flex flex-col gap-4">

        <!-- Canales de contacto -->
        <div class="rounded-2xl overflow-hidden" style="background:rgba(10,25,47,0.8);border:1px solid rgba(21,94,117,0.35);backdrop-filter:blur(12px);">
          <div class="px-6 py-4 border-b" style="border-color:rgba(21,94,117,0.25);">
            <span class="font-mono text-xs tracking-widest uppercase" style="color:rgba(100,255,218,0.45);">Canales directos</span>
          </div>

          <!-- Email -->
          <a href={`https://mail.google.com/mail/?view=cm&fs=1&to=${email}`}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-row flex items-center gap-4 px-6 py-4 border-b transition-all duration-200"
            style="border-color:rgba(21,94,117,0.2);text-decoration:none;">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(100,255,218,0.1);">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#64ffda" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
            </div>
            <div class="min-w-0">
                <p class="font-mono text-[10px] uppercase tracking-widest mb-0.5" style="color:rgba(100,255,218,0.45);">Email</p>
                <p class="text-sm font-medium truncate" style="color:#ecfeff;">{email}</p>
            </div>
            <svg class="ml-auto flex-shrink-0 w-3.5 h-3.5 opacity-30" fill="none" viewBox="0 0 24 24" stroke="#64ffda" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
            </a>

          <!-- WhatsApp -->
          <a href={whatsappLink} target="_blank" rel="noopener"
             class="contact-row flex items-center gap-4 px-6 py-4 border-b transition-all duration-200"
             style="border-color:rgba(21,94,117,0.2);text-decoration:none;">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(34,197,94,0.1);">
              <svg width="16" height="16" fill="#22c55e" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="min-w-0">
              <p class="font-mono text-[10px] uppercase tracking-widest mb-0.5" style="color:rgba(34,197,94,0.5);">WhatsApp</p>
              <p class="text-sm font-medium" style="color:#ecfeff;">{whatsapp}</p>
            </div>
            <svg class="ml-auto flex-shrink-0 w-3.5 h-3.5 opacity-30" fill="none" viewBox="0 0 24 24" stroke="#22c55e" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>

          <!-- Ubicación + Horario -->
          <div class="flex items-center gap-4 px-6 py-4">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(6,182,212,0.1);">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#06b6d4" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-mono text-[10px] uppercase tracking-widest mb-0.5" style="color:rgba(6,182,212,0.5);">Ubicación</p>
              <p class="text-sm font-medium" style="color:#ecfeff;">{ubicacion}</p>
              <p class="text-xs mt-0.5" style="color:rgba(165,243,252,0.4);">{horario}</p>
            </div>
          </div>
        </div>

        <!-- Redes sociales — compactas -->
        <div class="rounded-2xl overflow-hidden px-2" style="background:rgba(10,25,47,0.8);border:1px solid rgba(21,94,117,0.35);backdrop-filter:blur(12px);">
          <div class="px-6 py-4 border-b" style="border-color:rgba(21,94,117,0.25);">
            <span class="font-mono text-xs tracking-widest uppercase" style="color:rgba(100,255,218,0.45);">Redes sociales</span>
          </div>
          <div class="p-4 grid grid-cols-4 gap-2">

            <!-- YouTube 
            <a href={youtube} target="_blank" rel="noopener"
               class="social-btn flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl transition-all duration-200"
               style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.15);text-decoration:none;">
              <svg width="18" height="18" fill="#ef4444" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              <span class="font-mono text-[9px]" style="color:rgba(239,68,68,0.7);">YouTube</span>
            </a>-->

            <!-- Instagram 
            <a href={instagram} target="_blank" rel="noopener"
               class="social-btn flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl transition-all duration-200"
               style="background:rgba(236,72,153,0.08);border:1px solid rgba(236,72,153,0.15);text-decoration:none;">
              <svg width="18" height="18" fill="#ec4899" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              <span class="font-mono text-[9px]" style="color:rgba(236,72,153,0.7);">Instagram</span>
            </a>-->

            <!-- Facebook -->
            <a href={facebook} target="_blank" rel="noopener"
               class="social-btn flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl transition-all duration-200"
               style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.15);text-decoration:none;">
              <svg width="18" height="18" fill="#3b82f6" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              <span class="font-mono text-[9px]" style="color:rgba(59,130,246,0.7);">Facebook</span>
            </a>

            <!-- TikTok -->
            <a href={tiktok} target="_blank" rel="noopener"
               class="social-btn flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl transition-all duration-200"
               style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);text-decoration:none;">
              <svg width="18" height="18" fill="#fff" viewBox="0 0 24 24">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
              <span class="font-mono text-[9px]" style="color:rgba(255,255,255,0.5);">TikTok</span>
            </a>
          </div>
        </div>

        <!-- Tiempo de respuesta -->
        <div class="flex items-center gap-3 px-5 py-4 rounded-2xl" style="background:rgba(100,255,218,0.05);border:1px solid rgba(100,255,218,0.12);">
          <div style="width:8px;height:8px;border-radius:50%;background:#64ffda;box-shadow:0 0 8px #64ffda;flex-shrink:0;animation:pulse-dot 2s infinite;"></div>
          <p class="text-xs" style="color:rgba(165,243,252,0.6);">
            Tiempo de respuesta promedio: <strong style="color:#64ffda;">menos de 24h</strong>
          </p>
        </div>

      </div>

      <!-- COLUMNA DERECHA — Formulario -->
      <div class="xl:col-span-8">
        <div class="relative rounded-2xl overflow-hidden" style="background:rgba(10,25,47,0.8);border:1px solid rgba(21,94,117,0.35);backdrop-filter:blur(12px);">

          <!-- Línea superior degradada -->
          <div class="h-px w-full" style="background:linear-gradient(90deg,transparent 0%,#64ffda 30%,#06b6d4 70%,transparent 100%);"></div>

          <div class="p-8">
            <!-- Header formulario -->
            <div class="flex items-center justify-between mb-8">
              <div>
                <h2 class="font-display font-bold text-xl" style="color:#ecfeff;">Envíanos un mensaje</h2>
                <p class="text-xs mt-1 font-mono" style="color:rgba(100,255,218,0.4);">Todos los campos marcados con * son obligatorios</p>
              </div>
              <!-- Indicador online -->
              <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full" style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);">
                <div style="width:6px;height:6px;border-radius:50%;background:#22c55e;animation:pulse-dot 2s infinite;"></div>
                <span class="font-mono text-[10px]" style="color:#22c55e;">Online</span>
              </div>
            </div>

            <form id="contactForm" class="space-y-5" novalidate>

              <!-- Fila 1: Nombre + Email -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="block font-mono text-[10px] uppercase tracking-[2px] mb-2" style="color:rgba(100,255,218,0.5);">
                    Nombre *
                  </label>
                  <div class="relative">
                    <input id="nombre" name="nombre" type="text" required
                           placeholder="Tu nombre completo"
                           class="cf-input w-full px-4 py-3 text-sm rounded-xl outline-none transition-all duration-200"
                           style="background:rgba(2,12,27,0.7);border:1px solid rgba(21,94,117,0.4);color:#ecfeff;"/>
                  </div>
                  <p class="cf-error hidden mt-1.5 text-xs" style="color:#f87171;" id="err-nombre">Ingresa tu nombre.</p>
                </div>
                <div>
                  <label class="block font-mono text-[10px] uppercase tracking-[2px] mb-2" style="color:rgba(100,255,218,0.5);">
                    Email *
                  </label>
                  <input id="email-input" name="email" type="email" required
                         placeholder="tu@email.com"
                         class="cf-input w-full px-4 py-3 text-sm rounded-xl outline-none transition-all duration-200"
                         style="background:rgba(2,12,27,0.7);border:1px solid rgba(21,94,117,0.4);color:#ecfeff;"/>
                  <p class="cf-error hidden mt-1.5 text-xs" style="color:#f87171;" id="err-email">Email no válido.</p>
                </div>
              </div>

              <!-- Fila 2: Tema -->
              <div>
                <label class="block font-mono text-[10px] uppercase tracking-[2px] mb-2" style="color:rgba(100,255,218,0.5);">
                  ¿Sobre qué tema?
                </label>
                <select id="tema" name="tema"
                        class="cf-input w-full px-4 py-3 text-sm rounded-xl outline-none transition-all duration-200 cursor-pointer"
                        style="background:rgba(2,12,27,0.7);border:1px solid rgba(21,94,117,0.4);color:#ecfeff;">
                  <option value="" style="background:#0a192f;">Selecciona un tema…</option>
                  <option value="consulta-manual"   style="background:#0a192f;">📋 Consulta sobre un manual</option>
                  <option value="sugerencia"        style="background:#0a192f;">💡 Sugerir nuevo manual</option>
                  <option value="melamina"          style="background:#0a192f;">🪵 Pregunta de Melamina</option>
                  <option value="madera"            style="background:#0a192f;">🌳 Pregunta de Madera</option>
                  <option value="mdf"               style="background:#0a192f;">📦 Pregunta de MDF</option>
                  <option value="herramientas"      style="background:#0a192f;">🔧 Pregunta de Herramientas</option>
                  <option value="colaboracion"      style="background:#0a192f;">🤝 Colaboración / Patrocinio</option>
                  <option value="otro"              style="background:#0a192f;">✉️ Otro</option>
                </select>
              </div>

              <!-- Fila 3: Mensaje -->
              <div>
                <label class="block font-mono text-[10px] uppercase tracking-[2px] mb-2" style="color:rgba(100,255,218,0.5);">
                  Mensaje *
                </label>
                <textarea id="mensaje" name="mensaje" required rows="5"
                          placeholder="Cuéntanos tu consulta con el mayor detalle posible. Mientras más detalles nos des, mejor podemos ayudarte."
                          class="cf-input w-full px-4 py-3 text-sm rounded-xl outline-none transition-all duration-200 resize-none"
                          style="background:rgba(2,12,27,0.7);border:1px solid rgba(21,94,117,0.4);color:#ecfeff;"></textarea>
                <div class="flex items-center justify-between mt-1.5">
                  <p class="cf-error hidden text-xs" style="color:#f87171;" id="err-mensaje">El mensaje no puede estar vacío.</p>
                  <p id="char-count" class="ml-auto font-mono text-[10px]" style="color:rgba(100,255,218,0.3);">0 / 500</p>
                </div>
              </div>

              <!-- Submit -->
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-2">
                <button id="submitBtn" type="submit"
                        class="submit-btn relative overflow-hidden flex items-center gap-3 px-8 py-3.5 rounded-xl font-bold text-sm transition-all duration-300"
                        style="background:linear-gradient(135deg,#0891b2,#06b6d4);color:#fff;min-width:200px;justify-content:center;">
                  <span id="btnIcon">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
                    </svg>
                  </span>
                  <span id="btnText">Enviar mensaje</span>
                </button>
                <p class="text-xs" style="color:rgba(165,243,252,0.3);">
                  Al enviar aceptas nuestra
                  <a href="/privacidad" style="color:rgba(100,255,218,0.5);text-decoration:underline;">política de privacidad</a>.
                </p>
              </div>

              <!-- Success -->
              <div id="successMsg" class="hidden flex items-center gap-3 p-4 rounded-xl"
                   style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.25);">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="#22c55e" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <p class="text-sm font-bold" style="color:#86efac;">¡Mensaje enviado correctamente!</p>
                  <p class="text-xs mt-0.5" style="color:rgba(134,239,172,0.7);">Te respondemos en menos de 24 horas.</p>
                </div>
              </div>

            </form>
          </div>
        </div>

        <!-- FAQ compacto debajo del form -->
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { q: '¿Los manuales son gratis?', a: 'Sí, 100% gratuitos. Siempre.' },
            { q: '¿Puedo pedir un manual?', a: 'Claro, escríbenos con los detalles de tu proyecto.' },
            { q: '¿Hacen asesorías?', a: 'Por ahora no, toda la ayuda es vía manuales y contacto.' },
            { q: '¿En cuánto responden?', a: 'En menos de 24h en días hábiles.' },
          ].map(faq => (
            <div class="p-4 rounded-xl" style="background:rgba(10,25,47,0.6);border:1px solid rgba(21,94,117,0.25);">
              <p class="text-xs font-bold mb-1" style="color:#a5f3fc;">{faq.q}</p>
              <p class="text-xs" style="color:rgba(165,243,252,0.5);">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</div>

<style>
@keyframes pulse-dot {
  0%,100% { opacity:1; box-shadow:0 0 6px currentColor; }
  50% { opacity:0.6; box-shadow:0 0 14px currentColor; }
}
.cf-input::placeholder { color:rgba(165,243,252,0.2); }
.cf-input:focus {
  border-color:rgba(100,255,218,0.5) !important;
  box-shadow:0 0 0 3px rgba(100,255,218,0.06);
}
.contact-row:hover { background:rgba(100,255,218,0.04); }
.social-btn:hover { transform:translateY(-2px); filter:brightness(1.2); }
.submit-btn:hover {
  transform:translateY(-1px);
  box-shadow:0 8px 28px rgba(6,182,212,0.4);
}
.submit-btn:active { transform:translateY(0); }
</style>

<script>
const form        = document.getElementById('contactForm') as HTMLFormElement;
const btnText     = document.getElementById('btnText')!;
const submitBtn   = document.getElementById('submitBtn') as HTMLButtonElement;
const successMsg  = document.getElementById('successMsg')!;
const mensajeEl   = document.getElementById('mensaje') as HTMLTextAreaElement;
const charCount   = document.getElementById('char-count')!;

// Contador de caracteres
mensajeEl.addEventListener('input', () => {
  const len = mensajeEl.value.length;
  charCount.textContent = `${len} / 500`;
  charCount.style.color = len > 450 ? '#f87171' : 'rgba(100,255,218,0.3)';
});

function showErr(id: string, show: boolean) {
  document.getElementById(id)!.classList.toggle('hidden', !show);
}

form.addEventListener('submit', (e) => {
  e.preventDefault();
  const nombre  = (document.getElementById('nombre')      as HTMLInputElement).value.trim();
  const email   = (document.getElementById('email-input') as HTMLInputElement).value.trim();
  const mensaje = mensajeEl.value.trim();
  const tema    = (document.getElementById('tema')        as HTMLSelectElement).value;

  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  showErr('err-nombre',  !nombre);
  showErr('err-email',   !emailOk);
  showErr('err-mensaje', !mensaje);
  if (!nombre || !emailOk || !mensaje) return;

  submitBtn.disabled = true;
  btnText.textContent = 'Abriendo Gmail…';

  const subject = encodeURIComponent(`[CarpinteríaPro] ${tema || 'Consulta'} — ${nombre}`);
  const body    = encodeURIComponent(`Nombre: ${nombre}\nEmail: ${email}\nTema: ${tema}\n\nMensaje:\n${mensaje}`);

  // ✅ Abre Gmail directamente
  const gmailUrl = `https://mail.google.com/mail/?view=cm&fs=1&to=ventashot68@gmail.com&su=${subject}&body=${body}`;
  window.open(gmailUrl, '_blank', 'noopener,noreferrer');

  setTimeout(() => {
    submitBtn.disabled = false;
    btnText.textContent = 'Enviar mensaje';
    successMsg.classList.remove('hidden');
    form.reset();
    charCount.textContent = '0 / 500';
    setTimeout(() => successMsg.classList.add('hidden'), 6000);
  }, 1200);
});
</script>

</BaseLayout>