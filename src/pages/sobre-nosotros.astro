---
// src/pages/sobre-nosotros.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sobre Nosotros – CarpinteríaPro"
  description="Somos un equipo apasionado por la carpintería. Creamos manuales prácticos y detallados para que puedas construir tus propios muebles desde cero."
  keywords="sobre nosotros carpinteria, quienes somos, carpinteria peru, manuales carpinteria"
>

  <!-- ── HERO ── -->
  <section class="relative overflow-hidden py-20" style="background:var(--color-bark-950);">
    <div class="absolute pointer-events-none" style="width:500px;height:500px;left:50%;top:50%;transform:translate(-50%,-50%);background:radial-gradient(circle, color-mix(in srgb, var(--color-wood-500) 12%, transparent) 0%, transparent 65%);border-radius:50%;"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-[3px]"
           style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent); border:1px solid color-mix(in srgb, var(--color-wood-500) 28%, transparent); color:var(--color-wood-600);">
        <span style="width:6px;height:6px;border-radius:50%;background:var(--color-wood-500);display:inline-block;"></span>
        Nuestra historia
      </div>

      <h1 class="font-display font-black leading-none mb-6" style="font-size:clamp(36px,5vw,64px);color:var(--color-wood-100);letter-spacing:-1.5px;">
        Apasionados por<br/>
        <span style="color:var(--color-wood-500);">la carpintería</span>
      </h1>

      <p class="text-lg leading-relaxed max-w-2xl mx-auto" style="color:var(--color-wood-300);">
        Nació de una idea simple: que cualquier persona pueda construir sus propios muebles
        con las herramientas correctas, los materiales adecuados y una buena guía.
      </p>
    </div>
  </section>

  <!-- ── BREADCRUMB ── -->
  <div style="border-bottom:1px solid color-mix(in srgb, var(--color-wood-800) 50%, transparent); background:var(--color-bark-900);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs" style="color:var(--color-wood-400);" aria-label="Ruta de navegación">
        <a href="/" class="transition-colors" style="color:var(--color-wood-400);">Inicio</a>
        <span>/</span>
        <span style="color:var(--color-wood-200);">Sobre Nosotros</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- ── MISIÓN Y VISIÓN ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">

      <div class="relative p-8 rounded-2xl" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent); box-shadow:var(--shadow-soft);">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent); border:1px solid color-mix(in srgb, var(--color-wood-500) 25%, transparent);">
          <span class="text-2xl" aria-hidden="true">🎯</span>
        </div>
        <h2 class="font-display text-2xl font-bold mb-3" style="color:var(--color-wood-100);">Nuestra Misión</h2>
        <p class="leading-relaxed text-sm" style="color:var(--color-wood-400);">
          Democratizar el conocimiento de la carpintería en Perú y Latinoamérica.
          Creamos manuales claros, prácticos y detallados para que cualquier persona —
          sin importar su nivel — pueda construir muebles de calidad con melamina, madera, MDF y más.
        </p>
      </div>

      <div class="relative p-8 rounded-2xl" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent); box-shadow:var(--shadow-soft);">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:color-mix(in srgb, var(--color-olive-500) 12%, transparent); border:1px solid color-mix(in srgb, var(--color-olive-500) 28%, transparent);">
          <span class="text-2xl" aria-hidden="true">🔭</span>
        </div>
        <h2 class="font-display text-2xl font-bold mb-3" style="color:var(--color-wood-100);">Nuestra Visión</h2>
        <p class="leading-relaxed text-sm" style="color:var(--color-wood-400);">
          Ser la referencia número uno de manuales de carpintería en español.
          Queremos que cada persona pueda amueblar su hogar con sus propias manos,
          ahorrando dinero y ganando una habilidad para toda la vida.
        </p>
      </div>
    </div>

    <!-- ── STATS ── -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20">
      {[
        { num: '12+',  label: 'Manuales publicados',  icon: '📚' },
        { num: '5',    label: 'Categorías de material', icon: '🗂️' },
        { num: '100%', label: 'Contenido gratuito',   icon: '🎁' },
        { num: '2026', label: 'Año de fundación',     icon: '📅' },
      ].map(s => (
        <div class="text-center p-6 rounded-2xl" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
          <div class="text-3xl mb-2" aria-hidden="true">{s.icon}</div>
          <div class="font-display font-black text-4xl mb-1" style="color:var(--color-wood-500);">{s.num}</div>
          <div class="text-xs uppercase tracking-widest" style="color:var(--color-wood-400);">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- ── HISTORIA ── -->
    <div class="max-w-3xl mx-auto mb-20">
      <div class="text-center mb-10">
        <p class="eyebrow mb-3">Cómo empezamos</p>
        <h2 class="font-display text-3xl font-bold" style="color:var(--color-wood-100);">Nuestra Historia</h2>
      </div>

      <div class="space-y-0">
        {[
          {
            año: '2025',
            titulo: 'La idea nace',
            texto: 'Todo comenzó cuando quisimos renovar nuestros muebles y nos dimos cuenta que la información en español era escasa, incompleta o difícil de entender. Decidimos crear los manuales que nos hubiera gustado encontrar.',
            icon: '💡',
          },
          {
            año: '2026',
            titulo: 'Primer manual publicado',
            texto: 'Publicamos nuestro primer manual de melamina — una cocina completa paso a paso — y la respuesta fue increíble. Miles de personas lo encontraron útil y eso nos motivó a seguir.',
            icon: '🚀',
          },
          {
            año: '2026',
            titulo: 'Creciendo juntos',
            texto: 'Hoy tenemos más de 12 manuales en 5 categorías y seguimos creciendo. Cada semana publicamos nuevas guías basadas en las preguntas y necesidades de nuestra comunidad.',
            icon: '📈',
          },
        ].map((item, i) => (
          <div class="flex gap-6 relative">
            {i < 2 && (
              <div class="absolute left-[23px] top-14 bottom-0 w-px" style="background:color-mix(in srgb, var(--color-wood-800) 70%, transparent);"></div>
            )}
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-xl relative z-10"
                 style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent); border:1px solid color-mix(in srgb, var(--color-wood-500) 25%, transparent);">
              {item.icon}
            </div>
            <div class="pb-10 flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-bold px-2 py-1 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent); color:var(--color-wood-600);">
                  {item.año}
                </span>
                <h3 class="font-display font-bold text-lg" style="color:var(--color-wood-100);">{item.titulo}</h3>
              </div>
              <p class="text-sm leading-relaxed" style="color:var(--color-wood-400);">{item.texto}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── VALORES ── -->
    <div class="mb-20">
      <div class="text-center mb-10">
        <p class="eyebrow mb-3">Lo que nos mueve</p>
        <h2 class="font-display text-3xl font-bold" style="color:var(--color-wood-100);">Nuestros Valores</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: '🔍', titulo: 'Claridad ante todo', texto: 'Cada manual está escrito para ser entendido por cualquier persona. Sin tecnicismos innecesarios. Con fotos, medidas y listas de materiales exactas.' },
          { icon: '✅', titulo: 'Información verificada', texto: 'Todos nuestros manuales son probados antes de publicarse. Si un paso no funciona en la práctica, no lo publicamos.' },
          { icon: '🤝', titulo: 'Comunidad primero', texto: 'Escuchamos a nuestra comunidad. Los manuales que publicamos nacen de las preguntas y necesidades reales de nuestros lectores.' },
        ].map(v => (
          <div class="p-7 rounded-2xl transition-all duration-300 hover:-translate-y-1" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl mb-5" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);">
              {v.icon}
            </div>
            <h3 class="font-display font-bold text-lg mb-3" style="color:var(--color-wood-100);">{v.titulo}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--color-wood-400);">{v.texto}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- ── CTA ── -->
    <div class="relative overflow-hidden rounded-2xl p-10 text-center" style="background:color-mix(in srgb, var(--color-wood-500) 8%, var(--color-bark-900)); border:1px solid color-mix(in srgb, var(--color-wood-500) 22%, transparent);">
      <p class="eyebrow mb-4">¿Listo para empezar?</p>
      <h2 class="font-display text-3xl font-bold mb-4" style="color:var(--color-wood-100);">
        Comienza tu primer proyecto hoy
      </h2>
      <p class="text-sm leading-relaxed mb-8 max-w-xl mx-auto" style="color:var(--color-wood-400);">
        Explora todos nuestros manuales gratuitos y construye los muebles que siempre quisiste.
        Sin experiencia previa necesaria.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/manuales" class="btn-primary">Ver todos los manuales →</a>
        <a href="/contacto" class="btn-secondary">Contáctanos</a>
      </div>
    </div>

  </div>
</BaseLayout>
