---
// src/pages/sobre-nosotros.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sobre Nosotros – CarpinteríaPro"
  description="Somos un equipo apasionado por la carpintería. Creamos manuales prácticos y detallados para que puedas construir tus propios muebles desde cero."
  keywords="sobre nosotros carpinteria, quienes somos, carpinteria peru, manuales carpinteria"
>

  <!-- ── HERO ── -->
  <section class="relative overflow-hidden py-20" style="background:linear-gradient(135deg,#0a192f 0%,#020c1b 100%);">
    <!-- Grid de fondo -->
    <div class="absolute inset-0 pointer-events-none" style="
      background-image:linear-gradient(rgba(100,255,218,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(100,255,218,0.03) 1px,transparent 1px);
      background-size:60px 60px;
    "></div>
    <!-- Glow -->
    <div class="absolute pointer-events-none" style="width:500px;height:500px;left:50%;top:50%;transform:translate(-50%,-50%);background:radial-gradient(circle,rgba(6,182,212,0.1) 0%,transparent 65%);border-radius:50%;"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full font-mono text-xs font-bold uppercase tracking-[3px]"
           style="background:rgba(100,255,218,0.07);border:1px solid rgba(100,255,218,0.2);color:#64ffda;">
        <span style="width:6px;height:6px;border-radius:50%;background:#64ffda;display:inline-block;"></span>
        Nuestra historia
      </div>

      <h1 class="font-display font-black leading-none mb-6" style="font-size:clamp(36px,5vw,64px);color:#ecfeff;letter-spacing:-1.5px;">
        Apasionados por<br/>
        <span style="background:linear-gradient(135deg,#64ffda,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
          la carpintería
        </span>
      </h1>

      <p class="text-lg leading-relaxed max-w-2xl mx-auto" style="color:rgba(165,243,252,0.7);">
        Nació de una idea simple: que cualquier persona pueda construir sus propios muebles
        con las herramientas correctas, los materiales adecuados y una buena guía.
      </p>
    </div>
  </section>

  <!-- ── BREADCRUMB ── -->
  <div class="border-b border-(--color-wood-800)/20" style="background:rgba(2,12,27,0.5)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs" style="color:rgba(100,255,218,0.4)">
        <a href="/" class="hover:text-(--color-wood-300) transition-colors" style="color:rgba(100,255,218,0.4)">Inicio</a>
        <span>/</span>
        <span style="color:rgba(165,243,252,0.7)">Sobre Nosotros</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- ── MISIÓN Y VISIÓN ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">

      <div class="relative p-8 rounded-2xl overflow-hidden"
           style="background:var(--color-bark-900);border:1px solid rgba(100,255,218,0.15);">
        <div class="absolute top-0 left-0 right-0 h-0.5 rounded-t-2xl"
             style="background:linear-gradient(90deg,transparent,#64ffda,transparent)"></div>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5"
             style="background:rgba(100,255,218,0.1);border:1px solid rgba(100,255,218,0.2);">
          <span class="text-2xl">🎯</span>
        </div>
        <h2 class="font-display text-2xl font-bold mb-3" style="color:#ecfeff;">Nuestra Misión</h2>
        <p class="leading-relaxed text-sm" style="color:rgba(165,243,252,0.65);">
          Democratizar el conocimiento de la carpintería en Perú y Latinoamérica.
          Creamos manuales claros, prácticos y detallados para que cualquier persona —
          sin importar su nivel — pueda construir muebles de calidad con melamina, madera, MDF y más.
        </p>
      </div>

      <div class="relative p-8 rounded-2xl overflow-hidden"
           style="background:var(--color-bark-900);border:1px solid rgba(6,182,212,0.15);">
        <div class="absolute top-0 left-0 right-0 h-0.5 rounded-t-2xl"
             style="background:linear-gradient(90deg,transparent,#06b6d4,transparent)"></div>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5"
             style="background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.2);">
          <span class="text-2xl">🔭</span>
        </div>
        <h2 class="font-display text-2xl font-bold mb-3" style="color:#ecfeff;">Nuestra Visión</h2>
        <p class="leading-relaxed text-sm" style="color:rgba(165,243,252,0.65);">
          Ser la referencia número uno de manuales de carpintería en español.
          Queremos que cada persona pueda amueblar su hogar con sus propias manos,
          ahorrando dinero y ganando una habilidad para toda la vida.
        </p>
      </div>
    </div>

    <!-- ── STATS ── -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20">
      {[
        { num: '50+',   label: 'Manuales publicados',  icon: '📚', color: '#64ffda' },
        { num: '5',     label: 'Categorías de material', icon: '🗂️', color: '#06b6d4' },
        { num: '100%',  label: 'Contenido gratuito',   icon: '🎁', color: '#64ffda' },
        { num: '2026',  label: 'Año de fundación',     icon: '📅', color: '#06b6d4' },
      ].map(s => (
        <div class="text-center p-6 rounded-2xl" style="background:var(--color-bark-900);border:1px solid rgba(21,94,117,0.3);">
          <div class="text-3xl mb-2">{s.icon}</div>
          <div class="font-display font-black text-4xl mb-1" style={`color:${s.color}`}>{s.num}</div>
          <div class="text-xs uppercase tracking-widest" style="color:rgba(165,243,252,0.5)">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- ── HISTORIA ── -->
    <div class="max-w-3xl mx-auto mb-20">
      <div class="text-center mb-10">
        <p class="font-mono text-xs tracking-[3px] uppercase mb-3" style="color:rgba(100,255,218,0.5)">Cómo empezamos</p>
        <h2 class="font-display text-3xl font-bold" style="color:#ecfeff">Nuestra Historia</h2>
      </div>

      <div class="space-y-0">
        {[
          {
            año: '2025',
            titulo: 'La idea nace',
            texto: 'Todo comenzó cuando quisimos renovar nuestros muebles y nos dimos cuenta que la información en español era escasa, incompleta o difícil de entender. Decidimos crear los manuales que nos hubiera gustado encontrar.',
            icon: '💡',
          },
          {
            año: '2026',
            titulo: 'Primer manual publicado',
            texto: 'Publicamos nuestro primer manual de melamina — una cocina completa paso a paso — y la respuesta fue increíble. Miles de personas lo encontraron útil y eso nos motivó a seguir.',
            icon: '🚀',
          },
          {
            año: '2026',
            titulo: 'Creciendo juntos',
            texto: 'Hoy tenemos más de 12 manuales en 5 categorías y seguimos creciendo. Cada semana publicamos nuevas guías basadas en las preguntas y necesidades de nuestra comunidad.',
            icon: '📈',
          },
        ].map((item, i) => (
          <div class="flex gap-6 relative">
            <!-- Línea vertical -->
            {i < 2 && (
              <div class="absolute left-[23px] top-14 bottom-0 w-px" style="background:rgba(100,255,218,0.15)"></div>
            )}
            <!-- Círculo timeline -->
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-xl relative z-10"
                 style="background:rgba(100,255,218,0.1);border:1px solid rgba(100,255,218,0.25);">
              {item.icon}
            </div>
            <!-- Contenido -->
            <div class="pb-10 flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="font-mono text-xs font-bold px-2 py-1 rounded"
                      style="background:rgba(100,255,218,0.08);color:#64ffda;border:1px solid rgba(100,255,218,0.2)">
                  {item.año}
                </span>
                <h3 class="font-display font-bold text-lg" style="color:#ecfeff">{item.titulo}</h3>
              </div>
              <p class="text-sm leading-relaxed" style="color:rgba(165,243,252,0.6)">{item.texto}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── VALORES ── -->
    <div class="mb-20">
      <div class="text-center mb-10">
        <p class="font-mono text-xs tracking-[3px] uppercase mb-3" style="color:rgba(100,255,218,0.5)">Lo que nos mueve</p>
        <h2 class="font-display text-3xl font-bold" style="color:#ecfeff">Nuestros Valores</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            icon: '🔍',
            titulo: 'Claridad ante todo',
            texto: 'Cada manual está escrito para ser entendido por cualquier persona. Sin tecnicismos innecesarios. Con fotos, medidas y listas de materiales exactas.',
            color: '#64ffda',
          },
          {
            icon: '✅',
            titulo: 'Información verificada',
            texto: 'Todos nuestros manuales son probados antes de publicarse. Si un paso no funciona en la práctica, no lo publicamos.',
            color: '#06b6d4',
          },
          {
            icon: '🤝',
            titulo: 'Comunidad primero',
            texto: 'Escuchamos a nuestra comunidad. Los manuales que publicamos nacen de las preguntas y necesidades reales de nuestros lectores.',
            color: '#64ffda',
          },
        ].map(v => (
          <div class="p-7 rounded-2xl transition-all duration-300 hover:-translate-y-1"
               style="background:var(--color-bark-900);border:1px solid rgba(21,94,117,0.3);">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl mb-5"
                 style={`background:rgba(6,182,212,0.1);border:1px solid ${v.color}22`}>
              {v.icon}
            </div>
            <h3 class="font-display font-bold text-lg mb-3" style="color:#ecfeff">{v.titulo}</h3>
            <p class="text-sm leading-relaxed" style="color:rgba(165,243,252,0.6)">{v.texto}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- ── CTA ── -->
    <div class="relative overflow-hidden rounded-2xl p-10 text-center"
         style="background:linear-gradient(135deg,rgba(8,145,178,0.15),rgba(100,255,218,0.08));border:1px solid rgba(100,255,218,0.2);">
      <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(circle at 50% 50%,rgba(6,182,212,0.08) 0%,transparent 70%);"></div>
      <div class="relative">
        <p class="font-mono text-xs tracking-[3px] uppercase mb-4" style="color:rgba(100,255,218,0.6)">¿Listo para empezar?</p>
        <h2 class="font-display text-3xl font-bold mb-4" style="color:#ecfeff">
          Comienza tu primer proyecto hoy
        </h2>
        <p class="text-sm leading-relaxed mb-8 max-w-xl mx-auto" style="color:rgba(165,243,252,0.65);">
          Explora todos nuestros manuales gratuitos y construye los muebles que siempre quisiste.
          Sin experiencia previa necesaria.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/manuales"
             style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:12px;background:linear-gradient(135deg,#0891b2,#06b6d4);color:#fff;font-weight:700;font-size:15px;text-decoration:none;">
            Ver todos los manuales →
          </a>
          <a href="/contacto"
             style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:12px;background:rgba(100,255,218,0.08);border:1px solid rgba(100,255,218,0.25);color:#a5f3fc;font-weight:600;font-size:15px;text-decoration:none;">
            Contáctanos
          </a>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>