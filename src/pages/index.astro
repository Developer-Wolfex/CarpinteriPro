---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import CardManual from '../components/CardManual.astro';
import { MANUALES, CATEGORIAS, getManualesDestacados } from '../data/manuales';
import type { Categoria } from '../data/manuales';

const destacados = getManualesDestacados();
const categorias = Object.entries(CATEGORIAS) as [Categoria, typeof CATEGORIAS[Categoria]][];
---

<BaseLayout
  title="CarpinteríaPro – Manuales de Carpintería"
  description="Aprende carpintería con manuales detallados de melamina, madera, MDF y más. Guías paso a paso para todos los niveles."
  keywords="manuales carpinteria, melamina, madera, mdf, carpinteria, "
>

  <!-- ─── HERO ─── -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #020c1b 0%, #0a192f 50%, #020c1b 100%); min-height: 92vh; display: flex; align-items: center;">

    <!-- Fondo: grid lines estilo blueprint -->
    <div class="absolute inset-0 pointer-events-none" style="
      background-image:
        linear-gradient(rgba(100,255,218,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(100,255,218,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
    "></div>

    <!-- Glow orbs de fondo -->
    <div class="absolute pointer-events-none" style="width:600px;height:600px;right:-100px;top:50%;transform:translateY(-50%);background:radial-gradient(circle, rgba(6,182,212,0.12) 0%, transparent 70%);border-radius:50%;"></div>
    <div class="absolute pointer-events-none" style="width:400px;height:400px;left:-50px;bottom:-100px;background:radial-gradient(circle, rgba(8,145,178,0.08) 0%, transparent 70%);border-radius:50%;"></div>

    <!-- Línea de acento diagonal -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div style="position:absolute;top:0;right:35%;width:1px;height:100%;background:linear-gradient(180deg,transparent 0%,rgba(100,255,218,0.15) 30%,rgba(100,255,218,0.15) 70%,transparent 100%);"></div>
    </div>

    <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-6 items-center">

        <!-- ── COLUMNA IZQUIERDA: Texto ── -->
        <div class="relative z-10">

          <!-- Badge animado -->
          <div class="inline-flex items-center gap-2 mb-8" style="
            background: rgba(100,255,218,0.07);
            border: 1px solid rgba(100,255,218,0.2);
            border-radius: 9999px;
            padding: 6px 16px;
          ">
            <span style="width:6px;height:6px;border-radius:50%;background:#64ffda;box-shadow:0 0 8px #64ffda;display:inline-block;animation:pulse-dot 2s infinite;"></span>
            <span style="font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#64ffda;font-family:monospace;">
              Manuales Prácticos · Profesionales
            </span>
          </div>

          <!-- Título principal -->
          <h1 style="font-family:'Playfair Display',Georgia,serif;font-weight:900;line-height:1;margin-bottom:24px;">
            <span style="display:block;font-size:clamp(44px,6vw,80px);color:#ecfeff;letter-spacing:-2px;">
              Construye
            </span>
            <span style="display:block;font-size:clamp(44px,6vw,80px);letter-spacing:-2px;background:linear-gradient(135deg,#64ffda 0%,#06b6d4 50%,#0891b2 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
              con tus manos.
            </span>
          </h1>

          <!-- Descripción -->
          <p style="font-size:18px;line-height:1.7;color:rgba(165,243,252,0.75);max-width:480px;margin-bottom:40px;font-weight:300;">
            Guías paso a paso de carpintería en <strong style="color:#a5f3fc;font-weight:600;">melamina, madera y MDF</strong>.
            Con planos, medidas y listas de materiales para todos los niveles.
          </p>

          <!-- Stats rápidas -->
          <div class="flex items-center gap-8 mb-10" style="padding-bottom:32px;border-bottom:1px solid rgba(100,255,218,0.1);">
            {[
              { num: '+50',   label: 'Manuales' },
              { num: '5',     label: 'Categorías' },
              { num: '100%',  label: 'Gratis', amarillo: true , size:true},
            ].map(s => (
              <div>
                <div style={`font-size:${s.size ? '35px':"28px"}; font-weight:900;font-family:'Playfair Display',serif;line-height:1;color:${s.amarillo ? '#facc15' : '#64ffda'};`}>
                  {s.num}
                </div>
                <div style={`font-size:${s.size ? '16px':"11px"}; text-transform:uppercase;letter-spacing:2px;margin-top:2px;color:${s.amarillo ? 'rgba(250,204,21,0.6)' : 'rgba(100,255,218,0.4)'};`}>
                  {s.label}
                </div>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4">
            <a href="/manuales" style="
              display:inline-flex;align-items:center;gap:10px;
              padding:14px 28px;border-radius:12px;
              background:linear-gradient(135deg,#0891b2,#06b6d4);
              color:#fff;font-weight:700;font-size:15px;
              text-decoration:none;
              box-shadow:0 8px 32px rgba(6,182,212,0.35);
              transition:all .3s;
            "
            onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 40px rgba(6,182,212,0.5)'"
            onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 32px rgba(6,182,212,0.35)'">
              Ver todos los manuales
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>
        </div>

        <!-- ── COLUMNA DERECHA: Imagen sierra con degradado ── -->
        <div class="relative hidden lg:flex items-center justify-center">

          <!-- Glow detrás de la imagen -->
          <div class="absolute" style="width:500px;height:500px;background:radial-gradient(circle,rgba(6,182,212,0.18) 0%,transparent 65%);border-radius:50%;"></div>

          <!-- Contenedor con máscara de degradado en los bordes -->
          <div class="relative" style="
            width: 460px;
            height: 500px;

            /* ✅ AQUÍ está el truco: máscara con degradado en todos los bordes */
            -webkit-mask-image: radial-gradient(
              ellipse 85% 85% at 50% 50%,
              black 55%,
              transparent 100%
            );
            mask-image: radial-gradient(
              ellipse 85% 85% at 50% 50%,
              black 55%,
              transparent 100%
            );
          ">
            <img
              src="/image/sierra.png"
              alt="Sierra circular profesional"
              width="460"
              height="500"
              loading="eager"
              style="width:100%;height:100%;object-fit:contain;"
            />
          </div>

          <!-- Esquinas decorativas tipo blueprint -->
          <div class="absolute inset-0 pointer-events-none" style="width:460px;height:500px;margin:auto;">
            <div style="position:absolute;top:0;left:0;width:40px;height:40px;border-top:2px solid rgba(100,255,218,0.5);border-left:2px solid rgba(100,255,218,0.5);border-radius:4px 0 0 0;"></div>
            <div style="position:absolute;top:0;right:0;width:40px;height:40px;border-top:2px solid rgba(100,255,218,0.5);border-right:2px solid rgba(100,255,218,0.5);border-radius:0 4px 0 0;"></div>
            <div style="position:absolute;bottom:0;left:0;width:40px;height:40px;border-bottom:2px solid rgba(100,255,218,0.5);border-left:2px solid rgba(100,255,218,0.5);border-radius:0 0 0 4px;"></div>
            <div style="position:absolute;bottom:0;right:0;width:40px;height:40px;border-bottom:2px solid rgba(100,255,218,0.5);border-right:2px solid rgba(100,255,218,0.5);border-radius:0 0 4px 0;"></div>
          </div>

          <!-- Badges flotantes -->
          <div class="absolute" style="top:20px;right:-10px;">
            <div style="background:rgba(6,182,212,0.15);border:1px solid rgba(100,255,218,0.3);border-radius:10px;padding:8px 14px;backdrop-filter:blur(10px);">
              <div style="font-size:11px;font-weight:700;color:#64ffda;font-family:monospace;">✓ Calidad Pro</div>
              <div style="font-size:10px;color:rgba(165,243,252,0.6);">Herramienta premium</div>
            </div>
          </div>

          <div class="absolute" style="bottom:60px;left:-20px;">
            <div style="background:rgba(6,182,212,0.15);border:1px solid rgba(100,255,218,0.3);border-radius:10px;padding:8px 14px;backdrop-filter:blur(10px);">
              <div style="font-size:11px;font-weight:700;color:#64ffda;font-family:monospace;">⚡ 1200W</div>
              <div style="font-size:10px;color:rgba(165,243,252,0.6);">Sierra circular</div>
            </div>
          </div>

        </div>

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="opacity:0.5;">
      <span style="font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#64ffda;font-family:monospace;">scroll</span>
      <div style="width:1px;height:40px;background:linear-gradient(180deg,#64ffda,transparent);animation:scrollLine 2s ease-in-out infinite;"></div>
    </div>
  </section>

  <style>
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 8px #64ffda; opacity: 1; }
    50% { box-shadow: 0 0 16px #64ffda, 0 0 32px rgba(100,255,218,0.4); opacity: 0.7; }
  }
  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; opacity: 1; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
    100% { transform: scaleY(1); transform-origin: top; opacity: 0; }
  }
  </style>

  <!-- ─── CATEGORÍAS RÁPIDAS ─── -->
  <section class="py-14 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <p class="text-xs font-mono tracking-[4px] uppercase mb-3" style="color:rgba(100,255,218,0.5) " >Explora por material</p>
      <h2 class="section-title">¿Qué quieres aprender?</h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-5">
      {categorias.map(([key, cat]) => (
        <a
          href={`/manuales?cat=${key}`}
          class="group relative flex flex-col overflow-hidden rounded-2xl transition-all duration-300 hover:-translate-y-2"
          style="text-decoration:none;border:1px solid rgba(21,94,117,0.3);"
        >
          <!-- Imagen real del material -->
          <div class="relative h-36 overflow-hidden">
            <img
              src={cat.imagen}
              alt={cat.label}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Overlay gradiente oscuro -->
            <div class="absolute inset-0 transition-opacity duration-300"
                 style="background:linear-gradient(180deg,rgba(2,12,27,0.1) 0%,rgba(2,12,27,0.75) 100%);">
            </div>
            <!-- Overlay cian al hover -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                 style="background:rgba(6,182,212,0.15);">
            </div>
            <!-- Cantidad de manuales (badge top) -->
            <div class="absolute top-3 right-3">
              <span class="text-[14px] font-bold font-mono px-2 py-1 rounded-full"
                    style={`background:${cat.bgColor};color:${cat.textColor};backdrop-filter:blur(8px);border:1px solid ${cat.textColor}33`}>
                {MANUALES.filter(m => m.categoria === key).length}
              </span>
            </div>
          </div>

          <!-- Info del material -->
          <div class="p-4 flex flex-col gap-1 transition-colors duration-300"
               style="background:var(--color-bark-900)">
            <span class="font-display font-bold text-sm leading-tight"
                  style="color:#ecfeff">{cat.label}</span>
            <span class="text-[11px] leading-snug" style="color:rgba(165,243,252,0.5)">
              {cat.descripcion}
            </span>
            <!-- Flecha al hover -->
            <div class="flex items-center gap-1 mt-1 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0">
              <span class="text-[10px] font-mono font-bold" style={`color:${cat.textColor}`}>
                Ver manuales →
              </span>
            </div>
          </div>

          <!-- Borde inferior coloreado al hover -->
          <div class="absolute bottom-0 left-0 right-0 h-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
               style={`background:linear-gradient(90deg,transparent,${cat.textColor},transparent)`}>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ─── BANNER ADSENSE (parte superior contenido) ─── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
    <div class="bg-bark-900/50 border border-wood-800/20 rounded-xl p-3 text-center">
      <p class="text-wood-600 text-xs mb-2">PUBLICIDAD</p>
      <div class="bg-bark-800 rounded-lg h-[90px] flex items-center justify-center">
        <p class="text-wood-600 text-xs">Anuncio Banner 728×90 (AdSense)</p>
      </div>
    </div>
  </div>

  <!-- ─── MANUALES DESTACADOS ─── -->
  <section class="py-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title flex items-center gap-3">
        <span>⭐</span> Manuales Destacados
      </h2>
      <a href="/manuales" class="text-wood-400 hover:text-wood-200 text-sm font-bold transition-colors">
        Ver todos →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {destacados.map(manual => (
        <CardManual manual={manual} />
      ))}
    </div>
  </section>

  <!-- ─── TODOS POR CATEGORÍA (preview) ─── -->
  {categorias.slice(0, 3).map(([key, cat]) => {
    const manualesCategoria = MANUALES.filter(m => m.categoria === key).slice(0, 3);
    return (
      <section class="py-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="section-title flex items-center gap-3">
            <span>{cat.emoji}</span> {cat.label}
          </h2>
          <a href={`/manuales?cat=${key}`} class="text-wood-400 hover:text-wood-200 text-sm font-bold transition-colors">
            Ver todos de {cat.label} →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {manualesCategoria.map(manual => (
            <CardManual manual={manual} />
          ))}
        </div>
      </section>
    );
  })}

</BaseLayout>
