---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import CardManual from '../components/CardManual.astro';
import AdSense from '../components/AdSense.astro';
import { MANUALES, CATEGORIAS, getManualesDestacados } from '../data/manuales';
import type { Categoria } from '../data/manuales';

const destacados = getManualesDestacados();
const categorias = Object.entries(CATEGORIAS) as [Categoria, typeof CATEGORIAS[Categoria]][];
---

<BaseLayout
  title="CarpinteríaPro – Academia y Manuales de Carpintería"
  description="Aprende carpintería desde cero: materiales, proyectos prácticos, guía de melamina y manuales paso a paso, de nivel básico a avanzado."
  keywords="aprender carpinteria, manuales carpinteria, melamina, madera, mdf, carpinteria"
>

  <!-- ─── HERO ─── -->
  <section class="relative overflow-hidden" style="background:var(--color-bark-950);">
    <!-- Glow cálido de fondo -->
    <div class="absolute pointer-events-none" style="width:600px;height:600px;right:-120px;top:50%;transform:translateY(-50%);background:radial-gradient(circle, color-mix(in srgb, var(--color-wood-500) 14%, transparent) 0%, transparent 70%);border-radius:50%;"></div>
    <div class="absolute pointer-events-none" style="width:420px;height:420px;left:-80px;bottom:-100px;background:radial-gradient(circle, color-mix(in srgb, var(--color-olive-500) 12%, transparent) 0%, transparent 70%);border-radius:50%;"></div>

    <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-10 items-center">

        <!-- ── COLUMNA IZQUIERDA: Texto ── -->
        <div class="relative z-10">

          <div class="inline-flex items-center gap-2 mb-8 px-4 py-1.5 rounded-full"
               style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent); border:1px solid color-mix(in srgb, var(--color-wood-500) 28%, transparent);">
            <span style="width:6px;height:6px;border-radius:50%;background:var(--color-wood-500);display:inline-block;"></span>
            <span class="eyebrow">Manuales prácticos · profesionales</span>
          </div>

          <h1 class="font-display font-black leading-[0.95] mb-6" style="color:var(--color-wood-100);">
            <span class="block" style="font-size:clamp(40px,6vw,76px); letter-spacing:-1.5px;">
              Construye
            </span>
            <span class="block" style="font-size:clamp(40px,6vw,76px); letter-spacing:-1.5px; color:var(--color-wood-500);">
              con tus manos.
            </span>
          </h1>

          <p class="text-lg leading-relaxed max-w-md mb-10" style="color:var(--color-wood-300); font-weight:400;">
            Guías paso a paso de carpintería en <strong style="color:var(--color-wood-200); font-weight:600;">melamina, madera y MDF</strong>.
            Con planos, medidas y listas de materiales para todos los niveles.
          </p>

          <!-- Stats rápidas -->
          <div class="flex items-center gap-8 mb-10 pb-8" style="border-bottom:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
            {[
              { num: `${MANUALES.length}+`, label: 'Manuales' },
              { num: '5',     label: 'Categorías' },
              { num: '100%',  label: 'Gratis', destacar: true },
            ].map(s => (
              <div>
                <div class="font-display font-black leading-none" style={`font-size:${s.destacar ? '34px' : '28px'}; color:${s.destacar ? 'var(--color-wood-500)' : 'var(--color-wood-100)'};`}>
                  {s.num}
                </div>
                <div class="uppercase mt-1" style={`font-size:${s.destacar ? '12px' : '11px'}; letter-spacing:0.15em; color:var(--color-wood-400);`}>
                  {s.label}
                </div>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4">
            <a href="/manuales" class="btn-primary">
              Ver todos los manuales
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/sobre-nosotros" class="btn-secondary">
              Conócenos
            </a>
          </div>
        </div>

        <!-- ── COLUMNA DERECHA: Imagen sierra ── -->
        <div class="relative hidden lg:flex items-center justify-center">
          <div class="absolute" style="width:480px;height:480px;background:radial-gradient(circle, color-mix(in srgb, var(--color-wood-500) 16%, transparent) 0%, transparent 65%);border-radius:50%;"></div>

          <div class="relative" style="
            width: 440px;
            height: 480px;
            -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 50%, black 55%, transparent 100%);
            mask-image: radial-gradient(ellipse 85% 85% at 50% 50%, black 55%, transparent 100%);
          ">
            <img
              src="/image/sierra.png"
              alt="Sierra circular profesional de carpintería"
              width="440"
              height="480"
              loading="eager"
              fetchpriority="high"
              style="width:100%;height:100%;object-fit:contain;"
            />
          </div>

          <!-- Badges flotantes -->
          <div class="absolute" style="top:24px;right:-6px;">
            <div class="rounded-xl px-3.5 py-2" style="background:var(--color-bark-900);border:1px solid color-mix(in srgb, var(--color-wood-800) 70%, transparent);box-shadow:var(--shadow-soft);">
              <div class="text-xs font-bold" style="color:var(--color-wood-600);">✓ Calidad Pro</div>
              <div class="text-[10px]" style="color:var(--color-wood-400);">Herramienta premium</div>
            </div>
          </div>

          <div class="absolute" style="bottom:64px;left:-16px;">
            <div class="rounded-xl px-3.5 py-2" style="background:var(--color-bark-900);border:1px solid color-mix(in srgb, var(--color-wood-800) 70%, transparent);box-shadow:var(--shadow-soft);">
              <div class="text-xs font-bold" style="color:var(--color-wood-600);">⚡ 1200W</div>
              <div class="text-[10px]" style="color:var(--color-wood-400);">Sierra circular</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── ADSENSE: debajo del hero ─── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <AdSense slot="0000000002" format="horizontal" />
  </div>

  <!-- ─── ACADEMIA: portal educativo ─── -->
  <section class="py-14 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <p class="eyebrow mb-3">Academia CarpinteríaPro</p>
      <h2 class="section-title">Aprende, no solo copies un manual</h2>
      <p class="mt-3 max-w-xl mx-auto" style="color:var(--color-wood-400);">
        Una ruta de aprendizaje completa: materiales, fundamentos, proyectos reales y la guía especial de melamina.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { href: '/aprende', emoji: '🎓', titulo: 'Ruta de Aprendizaje', texto: 'De básico a avanzado, paso a paso.' },
        { href: '/materiales', emoji: '📐', titulo: 'Materiales', texto: 'Madera, MDF, MDP, triplay y más.' },
        { href: '/proyectos', emoji: '🛠️', titulo: 'Proyectos Prácticos', texto: 'Construcciones reales con pasos y errores comunes.' },
        { href: '/melamina', emoji: '🪵', titulo: 'Guía de Melamina', texto: 'Cortes, canteado, herrajes y costeo.' },
      ].map(card => (
        <a href={card.href} class="card-manual block p-6 text-center hover:-translate-y-1">
          <div class="text-3xl mb-3" aria-hidden="true">{card.emoji}</div>
          <h3 class="font-display font-bold text-base mb-2" style="color:var(--color-wood-100);">{card.titulo}</h3>
          <p class="text-xs leading-relaxed" style="color:var(--color-wood-400);">{card.texto}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ─── CATEGORÍAS RÁPIDAS ─── -->
  <section class="py-14 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <p class="eyebrow mb-3">Explora por material</p>
      <h2 class="section-title">¿Qué quieres aprender?</h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-5">
      {categorias.map(([key, cat]) => (
        <a
          href={`/manuales?cat=${key}`}
          class="group relative flex flex-col overflow-hidden rounded-2xl transition-all duration-300 hover:-translate-y-1.5"
          style="text-decoration:none; border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent); box-shadow:var(--shadow-soft);"
        >
          <div class="relative h-36 overflow-hidden">
            <img
              src={cat.imagen}
              alt={cat.label}
              width="280"
              height="144"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 transition-opacity duration-300"
                 style="background:linear-gradient(180deg, color-mix(in srgb, var(--color-wood-100) 5%, transparent) 0%, color-mix(in srgb, var(--color-wood-100) 55%, transparent) 100%);">
            </div>
            <div class="absolute top-3 right-3">
              <span class="text-[13px] font-bold px-2 py-1 rounded-full" style="background:var(--color-bark-900);color:var(--color-wood-600);box-shadow:var(--shadow-soft);">
                {MANUALES.filter(m => m.categoria === key).length}
              </span>
            </div>
          </div>

          <div class="p-4 flex flex-col gap-1" style="background:var(--color-bark-900);">
            <span class="font-display font-bold text-sm leading-tight" style="color:var(--color-wood-100);">{cat.label}</span>
            <span class="text-[11px] leading-snug" style="color:var(--color-wood-400);">
              {cat.descripcion}
            </span>
            <div class="flex items-center gap-1 mt-1 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0">
              <span class="text-[10px] font-bold" style="color:var(--color-wood-500);">
                Ver manuales →
              </span>
            </div>
          </div>

          <div class="absolute bottom-0 left-0 right-0 h-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background:var(--color-wood-500);"></div>
        </a>
      ))}
    </div>
  </section>

  <!-- ─── MANUALES DESTACADOS ─── -->
  <section class="py-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title flex items-center gap-3">
        <span aria-hidden="true">⭐</span> Manuales Destacados
      </h2>
      <a href="/manuales" class="text-sm font-bold transition-colors" style="color:var(--color-wood-500);">
        Ver todos →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {destacados.map(manual => (
        <CardManual manual={manual} />
      ))}
    </div>
  </section>

  <!-- ─── ADSENSE: entre secciones de contenido ─── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <AdSense slot="0000000003" format="horizontal" />
  </div>

  <!-- ─── TODOS POR CATEGORÍA (preview) ─── -->
  {categorias.slice(0, 3).map(([key, cat]) => {
    const manualesCategoria = MANUALES.filter(m => m.categoria === key).slice(0, 3);
    return (
      <section class="py-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="section-title flex items-center gap-3">
            <span aria-hidden="true">{cat.emoji}</span> {cat.label}
          </h2>
          <a href={`/manuales?cat=${key}`} class="text-sm font-bold transition-colors" style="color:var(--color-wood-500);">
            Ver todos de {cat.label} →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {manualesCategoria.map(manual => (
            <CardManual manual={manual} />
          ))}
        </div>
      </section>
    );
  })}

  <!-- ─── ADSENSE: antes del footer ─── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-4">
    <AdSense slot="0000000004" format="horizontal" />
  </div>

</BaseLayout>
