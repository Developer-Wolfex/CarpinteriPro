---
// src/pages/privacidad.astro
// IMPORTANTE PARA ADSENSE: Esta página es obligatoria.
// Personaliza los datos marcados con TODO antes de publicar.
import BaseLayout from '../layouts/BaseLayout.astro';

const fechaActualizacion = '7 de mayo de 2026'; // TODO: cambia esta fecha
const dominio = 'carpinteriapro.com';              // TODO: tu dominio real
const email = 'ventashot68@gmail.com';       // TODO: tu email real
const pais = 'Perú';                               // TODO: tu país
---

<BaseLayout
  title="Política de Privacidad – CarpinteríaPro"
  description="Política de privacidad de CarpinteríaPro. Información sobre cómo recopilamos, usamos y protegemos tus datos personales."
  keywords="politica de privacidad, carpinteria pro, datos personales"
>

  <!-- Breadcrumb -->
  <div style="border-bottom:1px solid color-mix(in srgb, var(--color-wood-800) 50%, transparent); background:var(--color-bark-900);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs" style="color:var(--color-wood-400);" aria-label="Ruta de navegación">
        <a href="/" style="color:var(--color-wood-400);">Inicio</a>
        <span>/</span>
        <span style="color:var(--color-wood-200);">Política de Privacidad</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 mb-5 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-[3px]"
           style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent); border:1px solid color-mix(in srgb, var(--color-wood-500) 28%, transparent); color:var(--color-wood-600);">
        🔒 Documento Legal
      </div>
      <h1 class="font-display font-black mb-4" style="font-size:clamp(32px,4vw,52px);color:var(--color-wood-100);letter-spacing:-1px;">
        Política de Privacidad
      </h1>
      <p class="text-sm" style="color:var(--color-wood-400);">
        Última actualización: {fechaActualizacion}
      </p>
    </div>

    <!-- Contenido -->
    <div class="space-y-10" style="color:var(--color-wood-300);">

      <!-- Intro -->
      <div class="p-6 rounded-2xl" style="background:color-mix(in srgb, var(--color-wood-500) 6%, transparent); border:1px solid color-mix(in srgb, var(--color-wood-500) 18%, transparent);">
        <p class="text-sm leading-relaxed">
          En <strong style="color:var(--color-wood-100);">CarpinteríaPro</strong> (<strong style="color:var(--color-wood-200);">{dominio}</strong>)
          nos comprometemos a proteger tu privacidad. Esta política explica qué información recopilamos,
          cómo la usamos y cuáles son tus derechos. Al usar nuestro sitio web, aceptas los términos
          descritos en este documento.
        </p>
      </div>

      <!-- Sección 1 -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">01</span>
          Información que recopilamos
        </h2>
        <div class="space-y-4 text-sm leading-relaxed">
          <p>Podemos recopilar los siguientes tipos de información:</p>
          <div class="space-y-3 ml-4">
            {[
              { titulo: 'Información de uso', texto: 'Páginas visitadas, tiempo en el sitio, enlaces en los que haces clic, dirección IP, tipo de navegador y sistema operativo. Esta información se recopila automáticamente mediante cookies y tecnologías similares.' },
              { titulo: 'Información que nos proporcionas', texto: 'Si nos contactas por correo electrónico, recopilamos tu nombre y dirección de email para responderte.' },
              { titulo: 'Cookies y tecnologías de seguimiento', texto: 'Usamos cookies propias y de terceros (como Google Analytics y Google AdSense) para mejorar la experiencia del sitio y mostrar publicidad relevante.' },
            ].map(item => (
              <div class="p-4 rounded-xl" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
                <h3 class="font-bold mb-1" style="color:var(--color-wood-200);">• {item.titulo}</h3>
                <p style="color:var(--color-wood-400);">{item.texto}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Sección 2 -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">02</span>
          Cómo usamos tu información
        </h2>
        <div class="text-sm leading-relaxed space-y-3">
          <p>Utilizamos la información recopilada para:</p>
          <ul class="space-y-2 ml-4">
            {[
              'Mejorar el contenido y la experiencia de navegación en nuestro sitio.',
              'Analizar el tráfico y el comportamiento de los usuarios mediante Google Analytics.',
              'Mostrar publicidad relevante mediante Google AdSense.',
              'Responder a tus consultas cuando nos contactas directamente.',
              'Cumplir con obligaciones legales aplicables.',
            ].map(item => (
              <li class="flex items-start gap-2">
                <span style="color:var(--color-wood-500);margin-top:2px;flex-shrink:0;">→</span>
                <span style="color:var(--color-wood-400);">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Sección 3 — Google AdSense -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">03</span>
          Publicidad y Google AdSense
        </h2>
        <div class="p-5 rounded-xl mb-4" style="background:color-mix(in srgb, #b58a2e 8%, transparent); border:1px solid color-mix(in srgb, #b58a2e 22%, transparent);">
          <p class="text-sm leading-relaxed" style="color:#8a6a23;">
            ⚠️ Esta sección es requerida por Google AdSense para la aprobación de tu sitio.
          </p>
        </div>
        <div class="text-sm leading-relaxed space-y-4">
          <p>
            Este sitio web utiliza <strong style="color:var(--color-wood-200);">Google AdSense</strong>, un servicio de publicidad de Google LLC,
            para mostrar anuncios. Google AdSense utiliza cookies para mostrar anuncios basados en
            las visitas anteriores del usuario a este sitio web y a otros sitios en Internet.
          </p>
          <p>
            El uso de cookies de publicidad por parte de Google permite a Google y sus socios
            mostrar anuncios basados en la visita del usuario a este sitio o a otros sitios en Internet.
          </p>
          <p>
            Los usuarios pueden <strong style="color:var(--color-wood-200);">inhabilitar la publicidad personalizada</strong> accediendo a
            <a href="https://www.google.com/settings/ads" target="_blank" rel="noopener" style="color:var(--color-wood-500);text-decoration:underline;">
              Configuración de anuncios de Google
            </a>.
            También pueden visitar
            <a href="https://www.aboutads.info" target="_blank" rel="noopener" style="color:var(--color-wood-500);text-decoration:underline;">
              www.aboutads.info
            </a>
            para inhabilitar el uso de cookies de publicidad personalizada por parte de proveedores terceros.
          </p>
          <p>
            Para más información sobre cómo Google usa los datos, visita:
            <a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="noopener" style="color:var(--color-wood-500);text-decoration:underline;">
              Cómo usa Google los datos cuando usas sitios o aplicaciones de nuestros socios
            </a>.
          </p>
        </div>
      </section>

      <!-- Sección 4 — Cookies -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">04</span>
          Cookies
        </h2>
        <div class="text-sm leading-relaxed space-y-4">
          <p>
            Las cookies son pequeños archivos de texto que se almacenan en tu dispositivo cuando visitas
            un sitio web. Usamos los siguientes tipos de cookies:
          </p>
          <div class="overflow-x-auto rounded-xl" style="border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
            <table class="w-full text-xs">
              <thead>
                <tr style="background:color-mix(in srgb, var(--color-wood-500) 8%, transparent); border-bottom:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
                  <th class="text-left p-4 font-bold" style="color:var(--color-wood-600);">Tipo</th>
                  <th class="text-left p-4 font-bold" style="color:var(--color-wood-600);">Proveedor</th>
                  <th class="text-left p-4 font-bold" style="color:var(--color-wood-600);">Propósito</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { tipo: 'Analíticas', proveedor: 'Google Analytics', proposito: 'Medir el tráfico y comportamiento de usuarios.' },
                  { tipo: 'Publicidad', proveedor: 'Google AdSense', proposito: 'Mostrar anuncios relevantes y personalizados.' },
                  { tipo: 'Funcionales', proveedor: 'Propias', proposito: 'Recordar preferencias de navegación.' },
                ].map((row, i) => (
                  <tr style={`border-bottom:1px solid color-mix(in srgb, var(--color-wood-800) 40%, transparent); background:${i % 2 === 0 ? 'transparent' : 'color-mix(in srgb, var(--color-wood-500) 3%, transparent)'}`}>
                    <td class="p-4 font-bold" style="color:var(--color-wood-200);">{row.tipo}</td>
                    <td class="p-4" style="color:var(--color-wood-400);">{row.proveedor}</td>
                    <td class="p-4" style="color:var(--color-wood-400);">{row.proposito}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p>
            Puedes controlar y eliminar las cookies desde la configuración de tu navegador.
            Ten en cuenta que deshabilitar las cookies puede afectar la funcionalidad del sitio.
          </p>
        </div>
      </section>

      <!-- Sección 5 -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">05</span>
          Compartir información con terceros
        </h2>
        <div class="text-sm leading-relaxed space-y-3">
          <p><strong style="color:var(--color-wood-100);">No vendemos, alquilamos ni comercializamos</strong> tu información personal a terceros.</p>
          <p>Podemos compartir información con:</p>
          <ul class="space-y-2 ml-4">
            {[
              'Google LLC (Analytics y AdSense) para análisis y publicidad.',
              'Proveedores de hosting para el funcionamiento del sitio.',
              'Autoridades legales cuando sea requerido por ley.',
            ].map(item => (
              <li class="flex items-start gap-2">
                <span style="color:var(--color-wood-500);margin-top:2px;flex-shrink:0;">→</span>
                <span style="color:var(--color-wood-400);">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Sección 6 -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">06</span>
          Tus derechos
        </h2>
        <div class="text-sm leading-relaxed space-y-3">
          <p>Tienes derecho a:</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {[
              { icon: '👁️', titulo: 'Acceso', texto: 'Solicitar una copia de los datos que tenemos sobre ti.' },
              { icon: '✏️', titulo: 'Rectificación', texto: 'Corregir datos inexactos o incompletos.' },
              { icon: '🗑️', titulo: 'Eliminación', texto: 'Solicitar que eliminemos tus datos personales.' },
              { icon: '🚫', titulo: 'Oposición', texto: 'Oponerte al procesamiento de tus datos para publicidad.' },
            ].map(d => (
              <div class="p-4 rounded-xl flex gap-3" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
                <span class="text-xl flex-shrink-0" aria-hidden="true">{d.icon}</span>
                <div>
                  <h3 class="font-bold text-xs mb-1" style="color:var(--color-wood-200);">{d.titulo}</h3>
                  <p class="text-xs" style="color:var(--color-wood-400);">{d.texto}</p>
                </div>
              </div>
            ))}
          </div>
          <p>
            Para ejercer cualquiera de estos derechos, contáctanos en:
            <a href={`mailto:${email}`} style="color:var(--color-wood-500);text-decoration:underline;">{email}</a>
          </p>
        </div>
      </section>

      <!-- Sección 7 -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">07</span>
          Seguridad de datos
        </h2>
        <p class="text-sm leading-relaxed">
          Implementamos medidas técnicas y organizativas razonables para proteger tu información
          contra acceso no autorizado, pérdida o alteración. Sin embargo, ninguna transmisión
          por internet es 100% segura. Usamos HTTPS en todo el sitio para cifrar la comunicación.
        </p>
      </section>

      <!-- Sección 8 -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">08</span>
          Menores de edad
        </h2>
        <p class="text-sm leading-relaxed">
          Este sitio web no está dirigido a menores de 13 años. No recopilamos conscientemente
          información personal de menores. Si eres padre o tutor y crees que tu hijo nos ha
          proporcionado información, contáctanos en <a href={`mailto:${email}`} style="color:var(--color-wood-500);text-decoration:underline;">{email}</a>.
        </p>
      </section>

      <!-- Sección 9 -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">09</span>
          Cambios a esta política
        </h2>
        <p class="text-sm leading-relaxed">
          Podemos actualizar esta política de privacidad ocasionalmente. Te notificaremos de
          cambios significativos publicando la nueva política en esta página con la fecha de
          actualización. Te recomendamos revisar esta página periódicamente.
          El uso continuado del sitio después de los cambios implica la aceptación de la nueva política.
        </p>
      </section>

      <!-- Sección 10 — Contacto -->
      <section>
        <h2 class="font-display font-bold text-2xl mb-4 flex items-center gap-3" style="color:var(--color-wood-100);">
          <span class="text-lg px-2 py-0.5 rounded" style="background:color-mix(in srgb, var(--color-wood-500) 10%, transparent);color:var(--color-wood-600);font-size:20px;">10</span>
          Contacto
        </h2>
        <div class="p-6 rounded-2xl" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
          <p class="text-sm leading-relaxed mb-4">
            Si tienes preguntas sobre esta Política de Privacidad o sobre cómo manejamos tus datos,
            puedes contactarnos:
          </p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-3">
              <span style="color:var(--color-wood-500);" aria-hidden="true">📧</span>
              <span style="color:var(--color-wood-300);">Email:</span>
              <a href={`mailto:${email}`} style="color:var(--color-wood-500);text-decoration:underline;">{email}</a>
            </div>
            <div class="flex items-center gap-3">
              <span style="color:var(--color-wood-500);" aria-hidden="true">🌐</span>
              <span style="color:var(--color-wood-300);">Sitio web:</span>
              <a href={`https://${dominio}`} style="color:var(--color-wood-500);text-decoration:underline;">{dominio}</a>
            </div>
            <div class="flex items-center gap-3">
              <span style="color:var(--color-wood-500);" aria-hidden="true">📍</span>
              <span style="color:var(--color-wood-300);">País:</span>
              <span style="color:var(--color-wood-400);">{pais}</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Última actualización -->
      <div class="pt-6" style="border-top:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
        <p class="text-xs text-center" style="color:var(--color-wood-400);">
          Última actualización: {fechaActualizacion} · {dominio}
        </p>
      </div>

    </div>
  </div>

</BaseLayout>
