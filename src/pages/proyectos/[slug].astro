---
// src/pages/proyectos/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import AdSense from '../../components/AdSense.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { titulo, descripcion, nivel, tiempoEstimado, dificultad, materiales, herramientas, fecha, keywords, categoriaMaterial } = entry.data;
const { Content } = await render(entry);

const proyectos = await getCollection('proyectos');
const relacionados = proyectos.filter(p => p.id !== entry.id && p.data.nivel === nivel).slice(0, 3);

const nivelStyle: Record<string, string> = {
  'Básico':     'color:var(--color-olive-600); background:color-mix(in srgb, var(--color-olive-500) 12%, transparent);',
  'Intermedio': 'color:var(--color-wood-600); background:color-mix(in srgb, var(--color-wood-500) 12%, transparent);',
  'Avanzado':   'color:var(--color-wood-700); background:color-mix(in srgb, var(--color-wood-700) 12%, transparent);',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: titulo,
  description: descripcion,
  totalTime: undefined,
  tool: herramientas.map(h => ({ '@type': 'HowToTool', name: h })),
  supply: materiales.map(m => ({ '@type': 'HowToSupply', name: m })),
};
---

<BaseLayout title={`${titulo} | CarpinteríaPro`} description={descripcion} keywords={keywords?.join(', ')} type="article">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Proyectos', href: '/proyectos' }, { label: titulo }]} />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <div class="flex flex-wrap items-center gap-3 mb-4">
      <span class="badge-category" style={nivelStyle[nivel]}>{nivel}</span>
      <span class="badge-category">{categoriaMaterial}</span>
      <span class="text-xs" style="color:var(--color-wood-400);">⏱ {tiempoEstimado}</span>
      <span class="text-xs" style="color:var(--color-wood-400);">{'●'.repeat(dificultad)}{'○'.repeat(5 - dificultad)} dificultad</span>
    </div>

    <h1 class="font-display text-3xl md:text-4xl font-black leading-tight mb-4" style="color:var(--color-wood-100);">{titulo}</h1>
    <p class="text-lg leading-relaxed mb-8" style="color:var(--color-wood-300);">{descripcion}</p>

    <!-- AdSense: debajo de la introducción -->
    <AdSense slot="0000000015" format="horizontal" className="mb-8" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
      <div class="rounded-xl p-5" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
        <h2 class="font-bold text-sm mb-3" style="color:var(--color-wood-200);">🧱 Materiales</h2>
        <ul class="space-y-1.5 text-sm" style="color:var(--color-wood-400);">
          {materiales.map(m => <li>• {m}</li>)}
        </ul>
      </div>
      <div class="rounded-xl p-5" style="background:var(--color-bark-900); border:1px solid color-mix(in srgb, var(--color-wood-800) 60%, transparent);">
        <h2 class="font-bold text-sm mb-3" style="color:var(--color-wood-200);">🛠️ Herramientas</h2>
        <ul class="space-y-1.5 text-sm" style="color:var(--color-wood-400);">
          {herramientas.map(h => <li>• {h}</li>)}
        </ul>
      </div>
    </div>

    <div class="prose max-w-none prose-headings:font-display prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-10 prose-h3:text-lg prose-h3:mt-6 prose-table:w-full prose-table:text-sm"
         style="color:var(--color-wood-300); --tw-prose-headings:var(--color-wood-100); --tw-prose-body:var(--color-wood-300); --tw-prose-bold:var(--color-wood-200); --tw-prose-th-borders:var(--color-wood-800); --tw-prose-td-borders:var(--color-wood-800);">
      <Content />
    </div>

    <!-- AdSense: antes del cierre del artículo -->
    <AdSense slot="0000000016" format="rectangle" className="mt-10" />

    {relacionados.length > 0 && (
      <div class="mt-12">
        <h2 class="font-display text-2xl font-bold mb-6" style="color:var(--color-wood-100);">
          <span aria-hidden="true">🔗</span> Más proyectos de nivel {nivel}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {relacionados.map(p => <ProjectCard proyecto={p} />)}
        </div>
      </div>
    )}

    <div class="mt-10 text-center">
      <a href="/proyectos" class="btn-secondary">← Ver todos los proyectos</a>
    </div>
  </div>
</BaseLayout>
